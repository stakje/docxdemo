<Application x:Class="DocVista.Updater.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
        <SolidColorBrush x:Key="OuterSpaceBrush" Color="#293742"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#80A3C8"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#91B0D0"/>
        <SolidColorBrush x:Key="BoneBrush" Color="#E0D8CD"/>
        <SolidColorBrush x:Key="BoneSoftBrush" Color="#F4F0EA"/>
        <SolidColorBrush x:Key="WengeBrush" Color="#5E5A51"/>
        <SolidColorBrush x:Key="DarkLavaBrush" Color="#47423A"/>
        <SolidColorBrush x:Key="LineBrush" Color="#C9C0B4"/>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Foreground" Value="{StaticResource OuterSpaceBrush}"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="{StaticResource AccentHoverBrush}"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
