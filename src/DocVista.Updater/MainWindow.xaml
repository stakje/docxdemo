<Window x:Class="DocVista.Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DocVista 更新" Width="520" Height="310" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" WindowStyle="None" Background="{StaticResource BoneSoftBrush}"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource DarkLavaBrush}">
    <Border BorderBrush="{StaticResource OuterSpaceBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="46"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource OuterSpaceBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0,6,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="25" Height="25" CornerRadius="5" Background="{StaticResource BoneBrush}">
                            <TextBlock Text="D" Foreground="{StaticResource OuterSpaceBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DocVista 更新" Foreground="{StaticResource BoneSoftBrush}" FontSize="13" FontWeight="SemiBold" Margin="9,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource BoneSoftBrush}" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="28,24,28,22">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="保持 DocVista 为最新版本" FontSize="21" FontWeight="SemiBold" Foreground="{StaticResource OuterSpaceBrush}"/>
                <TextBlock x:Name="VersionText" Grid.Row="1" Text="正在读取版本…" Foreground="{StaticResource WengeBrush}" FontSize="11" Margin="0,6,0,0"/>
                <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1"/>
                <TextBlock x:Name="StatusText" Grid.Row="3" Text="正在检查更新…" FontSize="13" Margin="0,16,0,10"/>
                <ProgressBar x:Name="DownloadProgress" Grid.Row="4" Height="5" Minimum="0" Maximum="100" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BoneBrush}" IsIndeterminate="True"/>
                <TextBlock x:Name="DetailText" Grid.Row="5" Foreground="{StaticResource WengeBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0"/>
                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="关闭" Width="78" Height="38" Background="Transparent" BorderBrush="{StaticResource LineBrush}" Foreground="{StaticResource DarkLavaBrush}" Cursor="Hand" Click="CloseButton_Click"/>
                    <Button x:Name="PrimaryButton" Style="{StaticResource ActionButton}" Content="检查更新" Margin="10,0,0,0" Click="PrimaryButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
