<Window x:Class="DocVista.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="DocVista" Width="1240" Height="780" MinWidth="860" MinHeight="560"
        WindowStyle="None" ResizeMode="CanResize" Background="{StaticResource BoneSoftBrush}"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource TextBrush}"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        PreviewKeyDown="Window_PreviewKeyDown" PreviewMouseWheel="Window_PreviewMouseWheel" Closing="Window_Closing" SizeChanged="Window_SizeChanged">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource OuterSpaceBrush}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="236"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource OuterSpaceBrush}" Padding="14,0,14,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource AccentBrush}">
                            <TextBlock Text="D" Foreground="White" FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DocVista" Foreground="{StaticResource SidebarTextBrush}" FontSize="16" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Row="1" Style="{StaticResource PrimaryButton}" Click="OpenButton_Click" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Margin="0,0,10,0"/>
                            <TextBlock Text="打开文档"/>
                            <TextBlock Text="Ctrl+O" Opacity="0.65" Margin="42,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Grid.Row="2" Text="最近打开" Foreground="{StaticResource SidebarMutedBrush}" FontSize="11" Margin="4,8,0,0"/>
                    <ListBox x:Name="RecentList" Grid.Row="3" Background="Transparent" BorderThickness="0" Margin="-4,8,-4,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="RecentList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,8"/><Setter Property="Margin" Value="0,1"/><Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemSurface" Padding="{TemplateBinding Padding}" CornerRadius="5" Background="Transparent">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#334651"/></Trigger>
                                                <Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemSurface" Property="Background" Value="#3B5260"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                                    <Border Width="24" Height="28" CornerRadius="4" Background="{StaticResource DarkLavaBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Extension}" Foreground="{StaticResource BoneBrush}" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                        <TextBlock Text="{Binding Directory}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource SidebarMutedBrush}" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="28" Height="28" Foreground="{StaticResource SidebarMutedBrush}" Content="&#xE74D;" Tag="{Binding Path}" ToolTip="删除记录" Focusable="False" PreviewMouseLeftButtonDown="RemoveRecentButton_PreviewMouseLeftButtonDown" Click="RemoveRecentButton_Click" AutomationProperties.Name="删除最近记录"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="4">
                        <Button Background="Transparent" BorderThickness="0" Foreground="{StaticResource SidebarMutedBrush}" HorizontalContentAlignment="Left" Padding="5,8" Cursor="Hand" Click="SettingsButton_Click" AutomationProperties.Name="设置">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Margin="0,0,9,0"/><TextBlock Text="设置"/></StackPanel>
                        </Button>
                        <Button Background="Transparent" BorderThickness="0" Foreground="{StaticResource SidebarMutedBrush}" HorizontalContentAlignment="Left" Padding="5,8" Cursor="Hand" Click="UninstallButton_Click" AutomationProperties.Name="卸载 DocVista">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="0,0,9,0"/><TextBlock Text="卸载 DocVista"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="30"/></Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource DocumentSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource IconButton}" Content="&#xE700;" ToolTip="折叠侧栏" Click="SidebarButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Grid Grid.Column="1" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="DocumentTitle" Text="DocVista" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DocumentMeta" Grid.Column="1" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Style="{StaticResource IconButton}" Content="&#xE921;" ToolTip="最小化" Click="MinimizeButton_Click"/>
                            <Button x:Name="MaximizeButton" Style="{StaticResource IconButton}" Content="&#xE922;" ToolTip="最大化" Click="MaximizeButton_Click"/>
                            <Button x:Name="CloseButton" Style="{StaticResource IconButton}" Width="46" Content="&#xE8BB;" ToolTip="关闭" Click="CloseButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="10,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButton}" Content="&#xE8E5;" ToolTip="打开文档 (Ctrl+O)" Click="OpenButton_Click"/>
                            <Separator Margin="6,8" Background="{StaticResource LineBrush}"/>
                            <ComboBox x:Name="SheetSelector" Width="170" Height="30" Visibility="Collapsed" SelectionChanged="SheetSelector_SelectionChanged"/>
                        </StackPanel>
                        <Border Grid.Column="1" x:Name="SearchBox" Width="260" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="5" Visibility="Collapsed">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBox x:Name="SearchInput" Grid.Column="1" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" FontSize="12" TextChanged="SearchInput_TextChanged"/>
                                <Button Grid.Column="2" Style="{StaticResource IconButton}" Width="30" Height="30" Content="&#xE894;" ToolTip="清除搜索" Click="ClearSearchButton_Click"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="TableSummary" MaxWidth="130" TextTrimming="CharacterEllipsis" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                            <Separator Margin="8,8" Background="{StaticResource LineBrush}"/>
                            <Button Style="{StaticResource IconButton}" Width="30" Height="30" Content="&#xE71F;" ToolTip="缩小 (Ctrl+-)" Click="ZoomOutButton_Click" AutomationProperties.Name="缩小"/>
                            <Button x:Name="ZoomResetButton" Style="{StaticResource IconButton}" Width="48" Height="30" FontFamily="{StaticResource UiFont}" FontSize="11" Content="100%" ToolTip="重置缩放 (Ctrl+0)" Click="ZoomResetButton_Click" AutomationProperties.Name="重置缩放"/>
                            <Button Style="{StaticResource IconButton}" Width="30" Height="30" Content="&#xE8A3;" ToolTip="放大 (Ctrl++)" Click="ZoomInButton_Click" AutomationProperties.Name="放大"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" x:Name="ViewerArea" Background="{StaticResource CanvasBrush}" ClipToBounds="True">
                    <Grid x:Name="EmptyState">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460">
                            <Border Width="72" Height="82" CornerRadius="7" Background="{StaticResource DocumentSurfaceBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
                                <Grid><TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource AccentBrush}" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid>
                            </Border>
                            <TextBlock Text="打开一份文档" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,22,0,8"/>
                            <TextBlock Text="拖放文件到这里，或从电脑中选择" Foreground="{StaticResource MutedTextBrush}" FontSize="13" HorizontalAlignment="Center"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="选择文档" Width="112" Margin="0,22,0,0" Click="OpenButton_Click"/>
                            <TextBlock Text="PDF · DOCX · DOC · PPTX · PPT · XLSX · XLS · CSV" Foreground="{StaticResource WengeBrush}" FontSize="10" HorizontalAlignment="Center" Margin="0,18,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="LoadingState" Visibility="Collapsed" Background="{StaticResource ChromeBrush}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ProgressBar Width="180" Height="3" IsIndeterminate="True" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock x:Name="LoadingText" Text="正在打开文档…" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,14,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ErrorState" Visibility="Collapsed" Background="{StaticResource ChromeBrush}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="480">
                            <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource WengeBrush}" FontSize="30" HorizontalAlignment="Center"/>
                            <TextBlock Text="无法预览此文档" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,6"/>
                            <TextBlock x:Name="ErrorText" TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                            <Button Style="{StaticResource PrimaryButton}" Content="选择其他文件" Margin="0,18,0,0" Click="OpenButton_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="PdfViewerContainer" Visibility="Collapsed" Background="{StaticResource DocumentSurfaceBrush}"/>
                    <DataGrid x:Name="TableViewer" Visibility="Collapsed" Background="{StaticResource DocumentSurfaceBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0"
                              IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="True" CanUserResizeColumns="True"
                              HeadersVisibility="All" GridLinesVisibility="All" HorizontalGridLinesBrush="{StaticResource GridLineBrush}" VerticalGridLinesBrush="{StaticResource GridLineBrush}"
                              RowHeight="30" ColumnHeaderHeight="34" RowHeaderWidth="46" AlternatingRowBackground="{StaticResource DocumentSurfaceBrush}"
                              SelectionUnit="FullRow"
                              EnableRowVirtualization="True" EnableColumnVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource OuterSpaceBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowHeaderStyle>
                            <Style TargetType="DataGridRowHeader">
                                <Setter Property="Background" Value="{StaticResource GridHeaderBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                        </DataGrid.RowHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="6,0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#C7D8E8"/>
                                        <Setter Property="Foreground" Value="{StaticResource OuterSpaceBrush}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                    </DataGrid>
                    <ScrollViewer x:Name="OfficeViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="{StaticResource CanvasBrush}" ScrollChanged="OfficeViewer_ScrollChanged">
                        <StackPanel x:Name="OfficePagesPanel" Margin="0,12,0,24">
                            <StackPanel.LayoutTransform><ScaleTransform x:Name="OfficeScaleTransform" ScaleX="1" ScaleY="1"/></StackPanel.LayoutTransform>
                        </StackPanel>
                    </ScrollViewer>
                    <Grid x:Name="ShellViewerContainer" Visibility="Collapsed" Background="{StaticResource DocumentSurfaceBrush}"/>
                </Grid>

                <Border Grid.Row="3" Background="{StaticResource ChromeBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="10,0">
                    <Grid><TextBlock x:Name="StatusText" Text="就绪" Foreground="{StaticResource MutedTextBrush}" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="只读模式" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource WengeBrush}" FontSize="10"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
