<Window x:Class="DocVista.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="设置" Width="520" Height="610" ResizeMode="NoResize" WindowStyle="None"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BoneSoftBrush}"
        FontFamily="{StaticResource UiFont}" Foreground="{StaticResource TextBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="0" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="QuietButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource OuterSpaceBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BoneSoftBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="设置" FontSize="14" FontWeight="SemiBold" Margin="18,0" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Width="46" Content="&#xE8BB;" ToolTip="关闭" Click="CancelButton_Click" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="22,16,22,20">
                    <TextBlock Text="查看" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource OuterSpaceBrush}"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                        <TextBlock Text="默认缩放" VerticalAlignment="Center" FontSize="12"/>
                        <Slider x:Name="DefaultZoomSlider" Grid.Column="1" Minimum="50" Maximum="200" TickFrequency="10" ValueChanged="DefaultZoomSlider_ValueChanged"/>
                        <TextBlock x:Name="DefaultZoomValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="缩放步长" VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="ZoomStepCombo" Grid.Column="1" Height="30" HorizontalContentAlignment="Left"/>
                    </Grid>

                    <CheckBox x:Name="RememberZoomCheck" Content="在文档之间记忆缩放比例" Margin="160,12,0,0"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Office 显示" VerticalAlignment="Center" FontSize="12"/>
                        <ComboBox x:Name="OfficeModeCombo" Grid.Column="1" Height="30"/>
                    </Grid>

                    <Separator Margin="0,18,0,16" Background="{StaticResource LineBrush}"/>
                    <TextBlock Text="列表与表格" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource OuterSpaceBrush}"/>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                        <TextBlock Text="最近记录数量" VerticalAlignment="Center" FontSize="12"/>
                        <Slider x:Name="RecentLimitSlider" Grid.Column="1" Minimum="3" Maximum="30" TickFrequency="1" ValueChanged="RecentLimitSlider_ValueChanged"/>
                        <TextBlock x:Name="RecentLimitValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                        <TextBlock Text="表格行高" VerticalAlignment="Center" FontSize="12"/>
                        <Slider x:Name="RowHeightSlider" Grid.Column="1" Minimum="24" Maximum="44" TickFrequency="2" ValueChanged="RowHeightSlider_ValueChanged"/>
                        <TextBlock x:Name="RowHeightValue" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>

                    <Separator Margin="0,18,0,16" Background="{StaticResource LineBrush}"/>
                    <TextBlock Text="界面" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource OuterSpaceBrush}"/>
                    <CheckBox x:Name="AnimationsCheck" Content="启用界面过渡动画" Margin="0,14,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0" Padding="16,11">
                <Grid>
                    <Button Style="{StaticResource QuietButton}" HorizontalAlignment="Left" Content="恢复默认" Click="ResetButton_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource QuietButton}" Content="取消" Margin="0,0,8,0" Click="CancelButton_Click"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="保存" Width="84" Height="34" Click="SaveButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
