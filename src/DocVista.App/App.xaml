<Application x:Class="DocVista.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>
        <SolidColorBrush x:Key="OuterSpaceBrush" Color="#263642"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2F6FBA"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#285F9F"/>
        <SolidColorBrush x:Key="BoneBrush" Color="#F4F6F8"/>
        <SolidColorBrush x:Key="BoneSoftBrush" Color="#FAFBFC"/>
        <SolidColorBrush x:Key="WengeBrush" Color="#6F7880"/>
        <SolidColorBrush x:Key="DarkLavaBrush" Color="#3A4A56"/>
        <SolidColorBrush x:Key="TextBrush" Color="#25282B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#68717A"/>
        <SolidColorBrush x:Key="LineBrush" Color="#D9DEE3"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CanvasBrush" Color="#E9ECEF"/>
        <SolidColorBrush x:Key="ChromeBrush" Color="#F7F8FA"/>
        <SolidColorBrush x:Key="DocumentSurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GridHeaderBrush" Color="#F2F4F6"/>
        <SolidColorBrush x:Key="GridLineBrush" Color="#E1E5E9"/>
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#F7F9FA"/>
        <SolidColorBrush x:Key="SidebarMutedBrush" Color="#ACB7BF"/>
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource OuterSpaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource BoneSoftBrush}"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#EDF1F4"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Surface" Property="Background" Value="#E1E7EB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.35"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="{StaticResource AccentHoverBrush}"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="Surface" Property="Opacity" Value="0.82"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
